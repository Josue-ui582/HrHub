generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  presences Presence[]
}

enum Role {
  USER
  ADMIN
}

model Presence {
  id       String    @id @default(uuid())
  userId   Int
  date     DateTime
  checkIn  DateTime?
  checkOut DateTime?
  duration Int? // en minutes

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}
